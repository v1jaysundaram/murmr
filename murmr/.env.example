# Copy this file to .env and fill in your values.
# Lines starting with # are comments — they're ignored by the app.

# --- Audio & Transcription ---

# Whisper model size. Options: tiny (~75MB), base (~150MB), small (~500MB)
# Smaller = faster but less accurate. "small" is a good default.
WHISPER_MODEL=small

# Sample rate for mic recording. 16000 Hz is what Whisper expects — don't change this.
AUDIO_SAMPLERATE=16000

# --- Hotkey ---

# The key combo to hold while speaking.
# Format: modifier+modifier+key  (e.g. ctrl+shift+space, ctrl+alt+m)
HOTKEY_COMBO=ctrl+shift+space

# --- Notion (Phase 2 — leave blank for now) ---

# Your Notion integration token. Get it from https://www.notion.so/my-integrations
NOTION_TOKEN=

# The ID of the Notion page to log transcriptions to.
# Find it in the page URL: notion.so/Your-Page-Title-{THIS_PART}
NOTION_PAGE_ID=
