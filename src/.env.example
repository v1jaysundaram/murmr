# murmr — example config (copy to .env and fill in your values)

# ── Audio & Transcription ──────────────────────────────────────────────────
WHISPER_MODEL=small           # tiny | base | small
AUDIO_SAMPLERATE=16000
WHISPER_LANGUAGE=en           # set to blank for auto-detect

# ── Notion (optional) ─────────────────────────────────────────────────────
NOTION_TOKEN=
NOTION_PAGE_ID=
NOTION_PAGE_NAME=

# ── AI Cleanup (optional) ─────────────────────────────────────────────────
AI_ENABLED=false
OPENAI_API_KEY=               # sk-proj-...
OPENAI_MODEL=gpt-4o-mini      # or gpt-4o for higher quality

# ── UI ────────────────────────────────────────────────────────────────────
OVERLAY_THEME=dark            # dark | light
DOCK_X=
DOCK_Y=
